from distutils.core import setup, Extension
import  numpy

setup( 
    name = "Cube electrostatic interaction (OpenCL)", 
    ext_modules = [ 
        Extension( "_eint",
            sources = [ "qm3/utils/eint_ocl.c" ],
            include_dirs = [ numpy.get_include() ],
            extra_compile_args = [ '-O3' ],
        extra_link_args = [ '-lOpenCL' ]
       )
    ]
)
